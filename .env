# Benchmark
TPCH_SCALE_FACTOR=10
DBMS=postgres,mysql,sqlserver,oracle
QUERY_TIMEOUT_SECONDS=0
CREATE_INDEXES=true

# Requested protocol
SEQUENTIAL_ITERATIONS=10 #10
SPEEDUP_ITERATIONS=10  #10
SPEEDUP_THREADS=1,4,8,16
THROUGHPUT_QUERY_ID=1  
THROUGHPUT_SECONDS=120  #  120
THROUGHPUT_THREADS=1
CLEAR_CACHE_BETWEEN_RUNS=true

# PostgreSQL
POSTGRES_DB=tpch
POSTGRES_USER=tpch
POSTGRES_PASSWORD=tpchpass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MySQL
MYSQL_DATABASE=tpch
MYSQL_USER=tpch
MYSQL_PASSWORD=tpchpass
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_HOST=mysql
MYSQL_PORT=3306

# SQL Server
MSSQL_DB=tpch
MSSQL_USER=sa
MSSQL_SA_PASSWORD=StrongPassw0rd!
MSSQL_HOST=sqlserver
MSSQL_PORT=1433
MSSQL_PID=Developer

# Oracle Free
ORACLE_USER=tpch
ORACLE_PASSWORD=tpchpass
ORACLE_SYS_PASSWORD=StrongPassw0rd!
ORACLE_DSN=oracle:1521/FREEPDB1
